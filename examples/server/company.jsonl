{"type":"PolicyClause","data":{"title":"Region locality","text":"All customer data resides in the customer's selected region; no implicit cross-region replication.","status":"draft","slug":"pdr-c1"}}
{"type":"PolicyClause","data":{"title":"Cross-region transfers","text":"Cross-region data transfers require legal review and documented customer consent.","status":"draft","slug":"pdr-c2"}}
{"type":"PolicyClause","data":{"title":"EU territoriality","text":"EU customer data and derived artifacts never leave EU territory under any circumstance.","status":"draft","slug":"pdr-c3"}}
{"type":"PolicyClause","data":{"title":"Region tags in audit logs","text":"All audit log entries include the region tag of the originating data and the actor's region.","status":"draft","slug":"pdr-c4"}}
{"type":"PolicyClause","data":{"title":"Outbound contributions","text":"All OSS contributions are reviewed by the OSS committee before being made on company time.","status":"draft","slug":"poss-c1"}}
{"type":"PolicyClause","data":{"title":"20% time","text":"Engineers may contribute to upstream dependencies during their 20% time without prior approval.","status":"draft","slug":"poss-c2"}}
{"type":"PolicyClause","data":{"title":"Default outbound license","text":"Apache-2.0 is the default outbound license; deviations require legal sign-off.","status":"draft","slug":"poss-c3"}}
{"type":"PolicyClause","data":{"title":"Two technical interviewers","text":"Each candidate has at least two independent technical interviewers from different teams.","status":"draft","slug":"phr-c1"}}
{"type":"PolicyClause","data":{"title":"Structured rubric","text":"Interviewers score against the structured rubric (≥5 dimensions) before debrief.","status":"draft","slug":"phr-c2"}}
{"type":"PolicyClause","data":{"title":"48-hour decision SLA","text":"Hire/no-hire decisions are documented within 48 hours of the final interview.","status":"draft","slug":"phr-c3"}}
{"type":"PolicyClause","data":{"title":"Calibration cadence","text":"A hiring calibration session runs weekly while any req is open on the team.","status":"draft","slug":"phr-c4"}}
{"type":"PolicyClause","data":{"title":"No secrets in source","text":"Secrets must not appear in code, environment files, or tickets.","status":"draft","slug":"psec-c1"}}
{"type":"PolicyClause","data":{"title":"90-day rotation","text":"All long-lived secrets are rotated at least every 90 days.","status":"draft","slug":"psec-c2"}}
{"type":"PolicyClause","data":{"title":"Quarterly audit","text":"Secret inventory is audited quarterly by the security team with a report posted to the team channel.","status":"draft","slug":"psec-c3"}}
{"type":"PolicyClause","data":{"title":"Compromise SLA","text":"Compromised secrets are rotated within 1 hour of confirmed compromise.","status":"draft","slug":"psec-c4"}}
{"type":"PolicyClause","data":{"title":"7-year retention","text":"Customer data is retained for 7 years post-contract unless a deletion request is honored.","status":"draft","slug":"pcd-c1"}}
{"type":"PolicyClause","data":{"title":"Right to be forgotten","text":"Right-to-be-forgotten requests are honored within 30 days of receipt.","status":"draft","slug":"pcd-c2"}}
{"type":"PolicyClause","data":{"title":"Encryption baseline","text":"Customer data is encrypted at rest (AES-256+) and in transit (TLS 1.3+).","status":"draft","slug":"pcd-c3"}}
{"type":"PolicyClause","data":{"title":"Quarterly inventory","text":"Quarterly data inventory review with a written attestation by the data steward.","status":"draft","slug":"pcd-c4"}}

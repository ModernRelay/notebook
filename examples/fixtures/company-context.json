    { "type": "PolicyClause", "id": "pdr-c4", "policy_id": "policy-data-residency", "title": "Region tags in audit logs","text": "All audit log entries include the region tag of the originating data and the actor's region.",     "status": "draft" },

    { "type": "PolicyClause", "id": "poss-c1", "policy_id": "policy-oss",           "title": "Outbound contributions",   "text": "All OSS contributions are reviewed by the OSS committee before being made on company time.",        "status": "draft" },
    { "type": "PolicyClause", "id": "poss-c2", "policy_id": "policy-oss",           "title": "20% time",                 "text": "Engineers may contribute to upstream dependencies during their 20% time without prior approval.",  "status": "draft" },
    { "type": "PolicyClause", "id": "poss-c3", "policy_id": "policy-oss",           "title": "Default outbound license", "text": "Apache-2.0 is the default outbound license; deviations require legal sign-off.",                  "status": "draft" },


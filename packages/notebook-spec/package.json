{
  "name": "@omnigraph/notebook-spec",
  "version": "0.0.1",
  "private": true,
  "description": "Zod 4 schemas for the OmniGraph notebook YAML wire format (frozen v1).",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {

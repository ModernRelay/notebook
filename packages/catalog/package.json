{
  "name": "@omnigraph/catalog",
  "version": "0.0.1",
  "private": true,
  "description": "Renderer-agnostic lens catalog (Table, Path, Subgraph) — Zod author-prop schemas + descriptions + spec assembler.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@json-render/core": "^0.19.0",
    "@omnigraph/notebook-spec": "workspace:*",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}

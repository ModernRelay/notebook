{
  "name": "@omnigraph/tui",
  "version": "0.0.1",
  "private": true,
  "description": "Terminal renderer for OmniGraph notebooks via @json-render/ink.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "omnigraph-tui": "./bin/omnigraph-tui.js"
  },
  "files": ["bin", "dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@json-render/core": "^0.19.0",
    "@json-render/ink": "^0.19.0",
    "@omnigraph/catalog": "workspace:*",
    "@omnigraph/client": "workspace:*",
    "@omnigraph/executor": "workspace:*",
    "@omnigraph/fixture": "workspace:*",
    "@omnigraph/notebook-spec": "workspace:*",
    "ink": "^6.0.0",
    "react": "^19.2.6",
    "yaml": "^2.8.4"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "ink-testing-library": "^4.0.0",
    "vitest": "^4.1.5"
  }
}

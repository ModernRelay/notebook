{
  "name": "@modernrelay/notebook-core",
  "version": "0.0.1",
  "private": true,
  "description": "Notebook engine: Zod YAML schemas + ref/rawGq query model, the renderer-agnostic component/action catalog, and the capability-aware runtime. The @json-render/core analog — start here.",

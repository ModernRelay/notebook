{
  "name": "@omnigraph/client",
  "version": "0.0.1",
  "private": true,
  "description": "Typed HTTP client for omnigraph-server plus a capability-aware runtime Source adapter.",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@modernrelay/omnigraph": "^0.7.0",
    "@omnigraph/runtime": "workspace:*",
    "@omnigraph/notebook-spec": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^4.1.5"
  }
}
